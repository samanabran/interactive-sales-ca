# Contabo VPS Environment — copy to .env and fill in values
# Used by docker-compose.yml in contabo-deployment/

# ── PostgreSQL ──────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── Clerk Production Keys (from dashboard.clerk.com) ───
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_PRODUCTION_SECRET
CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_PRODUCTION_PUBLISHABLE

# ── Frontend build args ─────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_PRODUCTION_PUBLISHABLE

# ── Ollama ──────────────────────────────────────────────
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.1:latest
