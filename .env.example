# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# ============================================

# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from: https://dashboard.clerk.com
# Under: API Keys section

# Publishable Key (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret Key (starts with sk_test_ or sk_live_)
# ⚠️  NEVER expose this in frontend code
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# API CONFIGURATION
# ============================================

# Development API URL
VITE_API_BASE_URL=http://localhost:8787/api

# Production API URL (uncomment for production builds)
# VITE_API_BASE_URL=https://interactive-sales-ca.pages.dev/api

# ============================================
# ENVIRONMENT
# ============================================
VITE_ENVIRONMENT=development
# Options: development, staging, production

# ============================================
# APPLICATION
# ============================================
VITE_APP_NAME=Scholarix CRM
VITE_APP_VERSION=2.0.0

# ============================================
# CLOUDFLARE (For Wrangler CLI)
# ============================================
# These are set via wrangler secret put command
# DO NOT put them in .env file!
# 
# Run these commands to set secrets:
# wrangler secret put CLERK_SECRET_KEY
# wrangler secret put CLERK_PUBLISHABLE_KEY
# wrangler secret put ENCRYPTION_KEY

# ============================================
# OPTIONAL: FEATURE FLAGS
# ============================================
# VITE_ENABLE_CALL_RECORDING=true
# VITE_ENABLE_AI_ANALYSIS=false
# VITE_ENABLE_EMAIL_INTEGRATION=false
# VITE_ENABLE_SMS_NOTIFICATIONS=false

# ============================================
# OPTIONAL: ANALYTICS
# ============================================
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ============================================
# VITE_TWILIO_ACCOUNT_SID=xxxxxxxxxxxxxxxxxxxxx
# VITE_TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxx
# VITE_SENDGRID_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# GOOGLE GEMINI TTS (Free Human-Like Voices)
# ============================================
# Get free API key from: https://ai.google.dev/
# Free tier: Generous limits for development
# Models: Gemini 3.1 Flash TTS (latest, competes with ElevenLabs)
# Features: 30+ voices, 70+ languages, 200+ audio tags, multi-speaker
VITE_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# DEEPGRAM TTS (Optional - Aura-2 Human-Like Voices)
# ============================================
# Get $200 free credit: https://deepgram.com/signup
# Docs: https://developers.deepgram.com/docs/tts-models
# 40+ voices, sub-200ms latency, $0.030/1K characters after free credit
# Aura-2 models: aura-2-asteria-en, aura-2-zeus-en, aura-2-thalia-en, etc.
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ============================================
# OPENAI API CONFIGURATION
# ============================================
# Get API key from: https://platform.openai.com/api-keys
# Required for AI features like objection handling and live coaching
# Note: Keeping for fallback, but prefer Gemini TTS (free tier)

# OpenAI API Key (starts with sk-)
# ⚠️  For production, set this in Cloudflare Pages environment variables
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# OLLAMA (Local LLM on Contabo GPU)
# ============================================
# Ollama endpoint on Contabo VPS (pre-setup with GPU)
VITE_OLLAMA_BASE_URL=http://80.241.218.108:11434

# ============================================
# TTS SERVER (Edge TTS - Backup Free Option)
# ============================================
# Microsoft Edge TTS - Completely free, no API key, 200+ voices
# Running on Contabo: http://80.241.218.108:5050
VITE_TTS_SERVER_URL=http://80.241.218.108:5050

# ============================================
# NOTES FOR PRODUCTION
# ============================================
# 
# 1. Use environment-specific keys (pk_live_, sk_live_)
# 2. Set VITE_API_BASE_URL to production URL
# 3. Change VITE_ENVIRONMENT to "production"
# 4. Enable HTTPS and secure cookies
# 5. Set up proper CORS origins
# 6. Configure rate limiting
# 7. Enable monitoring and logging
# 
# ============================================
# VOICE AGENTS SETUP (Zero Cost Options)
# ============================================
# 
# Option 1: Google Gemini 3.1 Flash TTS (RECOMMENDED)
# - Get free API key: https://ai.google.dev/
# - 30+ human-like voices
# - 70+ languages supported
# - 200+ audio tags for emotion control
# - Multi-speaker dialogue support
# - Free tier with generous limits
# 
# Option 2: Microsoft Edge TTS (Completely Free)
# - No API key required
# - 200+ voices via Contabo server
# - Endpoint: http://80.241.218.108:5050
# - OpenAI-compatible API
# 
# Option 3: Ollama (Local on Contabo GPU)
# - Already pre-configured on your VPS
# - Models: llama3.1:8b, llama3.2:3b
# - Free unlimited usage
# 
# ============================================
