# ============================================
# Contabo Deployment Environment Variables
# Copy to .env and fill in values
# ============================================

# ============================================
# CLERK AUTHENTICATION
# ============================================
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# DATABASE (PostgreSQL on Contabo)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scholarix_crm
DB_USER=scholarix
DB_PASSWORD=your-secure-db-password-here

# ============================================
# REDIS (Queue & Cache)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# OPENAI API (for transcription, analysis)
# ============================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# OLLAMA (Local LLM on Contabo GPU)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
# Pre-setup models expected on Contabo:
# - llama3.1:8b (general purpose)
# - llama3.2:3b (fast responses)
# - mxbai-embed-large (embeddings)
# - whisper (speech-to-text)

# ============================================
# STORAGE (S3-compatible or local)
# ============================================
RECORDINGS_BUCKET=scholarix-recordings
# For S3-compatible storage (MinIO, Cloudflare R2):
# S3_ENDPOINT=https://s3.contabo.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

# ============================================
# CONTAINER IP (for inter-service communication)
# ============================================
CONTAINER_IP=80.241.218.108  # Your Contabo VPS IP

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
VITE_ENVIRONMENT=production
VITE_APP_NAME=Scholarix CRM
VITE_APP_VERSION=2.0.0

# ============================================
# SECURITY
# ============================================
ENCRYPTION_KEY=your-32-byte-encryption-key-here
JWT_SECRET=your-jwt-secret-here

# ============================================
# MONITORING (Optional)
# ============================================
# SENTRY_DSN=
# GRAFANA_URL=
# PROMETHEUS_ENABLED=true
