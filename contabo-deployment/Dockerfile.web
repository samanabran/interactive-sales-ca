# Multi-stage build for React frontend
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
# Must include devDependencies for Vite + TypeScript build
RUN npm ci

COPY . .

RUN npm run build

# Production stage: Nginx serves the compiled static files
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY contabo-deployment/nginx-web.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
